.rieta-chatbot{position:fixed;right:18px;bottom:18px;z-index:9999;font-family:Inter,Arial,sans-serif}.rieta-toggle{border:0;border-radius:999px;background:#0A5DB7;color:#fff;box-shadow:0 14px 36px rgba(8,59,122,.22);padding:12px 16px;display:flex;align-items:center;gap:8px;font-weight:900;cursor:pointer;font-size:14px}.rieta-panel{display:none;position:absolute;right:0;bottom:56px;width:min(370px,calc(100vw - 28px));background:#fff;border:1px solid rgba(8,59,122,.10);border-radius:20px;box-shadow:0 22px 60px rgba(8,59,122,.20);overflow:hidden}.rieta-chatbot.open .rieta-panel{display:block}.rieta-head{padding:14px 15px;background:linear-gradient(135deg,#083B7A,#0A5DB7);color:#fff;display:flex;justify-content:space-between;align-items:flex-start;gap:12px}.rieta-head strong{display:block;font-size:18px;line-height:1.2}.rieta-head small{display:block;font-size:12px;line-height:1.45;opacity:.9;margin-top:4px}.rieta-head button{border:0;background:rgba(255,255,255,.16);color:#fff;width:34px;height:34px;border-radius:12px;cursor:pointer;flex:0 0 auto}.rieta-body{height:315px;overflow-y:auto;padding:12px;background:#f8fcff;display:flex;flex-direction:column;gap:9px;scroll-behavior:smooth}.rieta-msg{padding:10px 12px;border-radius:14px;font-size:13.5px;line-height:1.5;max-width:90%;word-wrap:break-word}.rieta-msg.bot{background:#fff;color:#344054;border:1px solid rgba(8,59,122,.08);align-self:flex-start}.rieta-msg.user{background:#0A5DB7;color:#fff;align-self:flex-end}.rieta-topics{display:flex;flex-wrap:wrap;gap:7px;margin-top:2px}.rieta-topics button{border:1px solid rgba(10,93,183,.16);background:#fff;color:#083B7A;border-radius:999px;padding:8px 10px;font-size:12.5px;font-weight:850;cursor:pointer}.rieta-topics button:hover{background:#eef7fb}.rieta-form{display:flex;gap:8px;padding:10px;background:#fff;border-top:1px solid rgba(8,59,122,.08)}.rieta-form input{flex:1;border:1px solid rgba(8,59,122,.14);border-radius:14px;padding:11px 12px;outline:none;font-size:14px;min-width:0}.rieta-form input:focus{border-color:#0A5DB7;box-shadow:0 0 0 4px rgba(10,93,183,.08)}.rieta-form button{border:0;background:#20C997;color:#fff;border-radius:14px;width:44px;cursor:pointer;flex:0 0 auto}.rieta-support-form{display:none;gap:8px;padding:12px;background:#fff;border-top:1px solid rgba(8,59,122,.08)}.rieta-support-form.show{display:grid}.rieta-support-form strong{font-size:13px;color:#083B7A}.rieta-support-form input,.rieta-support-form textarea{width:100%;border:1px solid rgba(8,59,122,.14);border-radius:12px;padding:10px 11px;font-size:13px;outline:none;box-sizing:border-box}.rieta-support-form textarea{min-height:74px;resize:vertical}.rieta-support-form button{border:0;background:#0A5DB7;color:#fff;border-radius:13px;padding:11px 12px;font-weight:900;cursor:pointer}.language-switch{display:inline-flex;align-items:center;gap:4px;background:#f8fcff;border:1px solid rgba(8,59,122,.10);border-radius:999px;padding:4px}.language-switch a{display:inline-flex;align-items:center;justify-content:center;min-width:34px;height:28px;border-radius:999px;font-weight:900;font-size:12px;color:#083B7A;text-decoration:none}.language-switch a.active{background:#0A5DB7;color:#fff}.nav-actions .language-switch{margin-right:6px}@media(max-width:640px){.rieta-chatbot{right:12px;bottom:12px}.rieta-panel{bottom:54px;width:calc(100vw - 24px)}.rieta-body{height:290px}.rieta-toggle{padding:11px 14px}.language-switch{margin:8px 0}}